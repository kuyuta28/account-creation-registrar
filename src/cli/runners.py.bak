"""
cli/runners.py - Standalone batch runners used by root-level run_*.py scripts.

Each runner wires config / logger / repo / registrar and loops `count` times.
Separated from menu.py (SRP: batch runner != interactive menu).
"""
from __future__ import annotations

import asyncio
import functools
import sys
import time
from pathlib import Path

from ..config.settings import load_config
from ..core.browser import tile_rects
from ..mail.client import configure_mail
from ..core.logger import Logger
from ..core.storage import AccountRepository
from ..core.logger import make_log_fn
from ..services.chatgpt.registrar import ChatGPTRegistrar, _SharedCallbackServer
from ..services.elevenlabs.registrar import ElevenLabsRegistrar
from ..services.leonardo.registrar import LeonardoRegistrar
from ..services.klingai.registrar import save_session as kling_save_session
from ..services.twoslides.registrar import TwoSlidesRegistrar
from ..services.registry import make_registrar

_SEP = "=" * 60
_BAR = "-" * 60


def parse_count_arg(argv: list[str] | None = None, default: int = 1) -> int:
    """Return a positive count parsed from argv[1], or default on invalid input."""
    args = sys.argv if argv is None else argv
    if len(args) < 2:
        return default
    try:
        return max(1, int(args[1]))
    except (TypeError, ValueError):
        return default


def parse_workers_arg(argv: list[str] | None = None, default: int = 1) -> int:
    """Return parallel worker count from --workers / -w flag in argv."""
    args = sys.argv if argv is None else argv
    for i, arg in enumerate(args):
        if arg in ("--workers", "-w") and i + 1 < len(args):
            try:
                return max(1, int(args[i + 1]))
            except (TypeError, ValueError):
                return default
    return default


# ── parallel runner ──────────────────────────────────────────────────────────


def _worker_logger(cfg, worker_idx: int) -> Logger:
    """Logger for one worker — own log file at debug/worker_{n}/run.log, config drives the rest."""
    from dataclasses import replace
    worker_file = replace(cfg.log.file, path=f"debug/worker_{worker_idx}/run.log")
    worker_log_cfg = replace(cfg.log, file=worker_file)
    return Logger(f"worker.{worker_idx}", worker_log_cfg, cfg.base_dir)


async def _run_parallel_registrar(
    count: int,
    workers: int,
    title: str,
    registrar_factory,
    formatter,
    cfg_patcher=None,
    _cfg=None,
) -> None:
    """
    Run `count` registrations across `workers` parallel browser instances.
    Each worker owns one registrar (one browser) and runs its assigned tasks
    sequentially — so the browser is reused across tasks instead of restarted.
    cfg_patcher(cfg, worker_idx) -> cfg  — optional per-worker config override.
    _cfg — pre-loaded AppConfig; loaded from disk when None.
    """
    cfg = _cfg if _cfg is not None else load_config()
    configure_mail(cfg.mail.cooldown_sec, cfg.mail.max_consecutive_fails)
    repo = AccountRepository(cfg.base_dir, cfg.auth_sync)

    print(f"\n{_SEP}")
    print(f"  {title}  (target: {count}, workers: {workers})")
    print(f"{_SEP}")

    worker_tasks: list[list[int]] = [[] for _ in range(workers)]
    for i in range(count):
        worker_tasks[i % workers].append(i)

    rects = tile_rects(workers) if not cfg.headless else [None] * workers

    async def run_worker(worker_idx: int, task_indices: list) -> list:
        w_cfg = cfg_patcher(cfg, worker_idx) if cfg_patcher else cfg
        w_log = _worker_logger(w_cfg, worker_idx)
        registrar = registrar_factory(w_cfg, w_log, repo, window_rect=rects[worker_idx])
        results = []
        try:
            for task_idx in task_indices:
                w_log.log(f"[worker {worker_idx}] Starting task {task_idx + 1}/{count}")
                t0 = time.monotonic()
                try:
                    record = await registrar.register()
                    elapsed = time.monotonic() - t0
                    w_log.log(f"[worker {worker_idx}] Task {task_idx + 1} finished in {elapsed:.0f}s ({'ok' if record else 'failed'})")
                    results.append((task_idx, record))
                except Exception as exc:
                    elapsed = time.monotonic() - t0
                    w_log.log(f"[worker {worker_idx}] Task {task_idx + 1} error after {elapsed:.0f}s: {exc}")
                    results.append((task_idx, None))
        finally:
            await registrar.cleanup()
        return results

    all_worker_results = await asyncio.gather(*[
        run_worker(widx, tasks)
        for widx, tasks in enumerate(worker_tasks)
        if tasks
    ], return_exceptions=True)

    completed: list = []
    for worker_results in all_worker_results:
        if isinstance(worker_results, Exception):
            print(f"\n[worker] Error: {worker_results}")
            continue
        for task_idx, record in worker_results:
            completed.append(record)
            if record:
                formatter(record, sum(1 for r in completed if r), count)
            else:
                print(f"\n[task {task_idx + 1}] Registration failed.")

    ok = sum(1 for r in completed if r)
    print(f"\n{_BAR}\n  Created: {ok}/{count}\n{_BAR}")


async def _run_counted_registrar(count: int, title: str, registrar_factory, formatter) -> None:
    cfg = load_config()
    configure_mail(cfg.mail.cooldown_sec, cfg.mail.max_consecutive_fails)
    log = Logger("main", cfg.log, cfg.base_dir)
    repo = AccountRepository(cfg.base_dir, cfg.auth_sync)

    log.log(_SEP)
    log.log(f"  {title}  (target: {count})")
    log.log(_SEP)

    registrar = registrar_factory(cfg, log, repo)
    ok = 0
    try:
        for i in range(count):
            if count > 1:
                log.log(f"\n[{i + 1}/{count}] {'-' * 37}")
            record = await registrar.register()
            if record:
                ok += 1
                formatter(record, ok, count)
            else:
                print(f"\nRegistration failed [{i + 1}/{count}].")
            if i < count - 1:
                log.log(f"\nPausing {cfg.timeouts.batch_delay_sec}s...")
                await asyncio.sleep(cfg.timeouts.batch_delay_sec)
    finally:
        await registrar.cleanup()

    print(f"\n{_BAR}\n  Created: {ok}/{count}\n{_BAR}")


def run_elevenlabs(count: int = 1) -> None:
    def _print(record, ok: int, total: int) -> None:
        print(f"\n{_SEP}\nDONE [{ok}/{total}]\n{_SEP}")
        print(f"  Email:    {record.email}")
        print(f"  Password: {record.password}")
        print(f"  API Key:  {record.api_key}")
        print(_SEP)

    asyncio.run(_run_counted_registrar(count, "ElevenLabs Account Creator", ElevenLabsRegistrar, _print))


def run_chatgpt(count: int = 1, workers: int = 1) -> None:
    def _print(record, ok: int, total: int) -> None:
        print(f"\n{_SEP}\nDONE [{ok}/{total}]\n{_SEP}")
        print(f"  Email:         {record.email}")
        print(f"  Password:      {record.password}")
        print(f"  Account ID:    {record.account_id}")
        if record.refresh_token:
            print(f"  Refresh Token: {record.refresh_token[:40]}...")
        print(f"  Expires:       {record.expired}")
        print(_SEP)

    if workers > 1:
        cfg = load_config()
        shared_cb = _SharedCallbackServer(cfg.chatgpt.callback_port)

        async def _run_with_shared_cb():
            loop = asyncio.get_running_loop()
            shared_cb.start(loop)
            try:
                await _run_parallel_registrar(
                    count, workers, "ChatGPT Account Creator",
                    functools.partial(ChatGPTRegistrar, shared_callback_server=shared_cb),
                    _print,
                    _cfg=cfg,
                )
            finally:
                await shared_cb.stop()

        asyncio.run(_run_with_shared_cb())
    else:
        asyncio.run(_run_counted_registrar(count, "ChatGPT Account Creator", ChatGPTRegistrar, _print))


def run_leonardo(count: int = 1) -> None:
    def _print(record, ok: int, total: int) -> None:
        print(f"\n{_SEP}\nDONE [{ok}/{total}]\n{_SEP}")
        print(f"  Email:    {record.email}")
        print(f"  Password: {record.password}")
        print(_SEP)

    asyncio.run(_run_counted_registrar(count, "Leonardo AI Account Creator", LeonardoRegistrar, _print))


def run_auth_sync(target_dir: str | None = None) -> None:
    cfg = load_config()
    repo = AccountRepository(cfg.base_dir, cfg.auth_sync)
    destination = Path(target_dir) if target_dir else cfg.auth_sync.target_dir
    synced = repo.sync_auth_exports(destination)
    print(f"\n{_BAR}\n  Synced: {len(synced)} file(s)\n  Target:  {destination}\n{_BAR}")


def main_run_elevenlabs() -> None:
    run_elevenlabs(parse_count_arg())


def main_run_chatgpt() -> None:
    run_chatgpt(parse_count_arg(), parse_workers_arg())


def main_run_leonardo() -> None:
    run_leonardo(parse_count_arg())


def run_kling_session(gmail: str = "") -> None:
    """Mở browser, đợi user login Google vào Kling AI, lưu session cookies."""
    cfg = load_config()
    log = Logger("main", cfg.log, cfg.base_dir)
    repo = AccountRepository(cfg.base_dir, cfg.auth_sync)

    print(f"\n{_SEP}")
    print("  Kling AI — Lưu session Google")
    print(_SEP)

    record = asyncio.run(kling_save_session(cfg, log, repo, gmail_hint=gmail))

    print(f"\n{_BAR}")
    if record:
        print(f"  DONE")
        print(f"  Email:        {record.email}")
        print(f"  Session file: {record.api_key}")
    else:
        print("  FAILED — Session không được lưu.")
    print(_BAR)


def main_run_kling_session() -> None:
    gmail = sys.argv[1] if len(sys.argv) > 1 else ""
    run_kling_session(gmail)


def run_2slides(count: int = 1, workers: int = 1) -> None:
    def _print(record, ok: int, total: int) -> None:
        print(f"\n{_SEP}\nDONE [{ok}/{total}]\n{_SEP}")
        print(f"  Email:   {record.email}")
        print(f"  API Key: {record.api_key}")
        print(_SEP)

    if workers > 1:
        asyncio.run(_run_parallel_registrar(count, workers, "2slides Account Creator", TwoSlidesRegistrar, _print))
    else:
        asyncio.run(_run_counted_registrar(count, "2slides Account Creator", TwoSlidesRegistrar, _print))


def main_run_2slides() -> None:
    run_2slides(parse_count_arg(), parse_workers_arg())


def run_openrouter(count: int = 1, workers: int = 1) -> None:
    """FP runner — dùng registry + make_registrar, không dùng OOP class."""
    cfg = load_config()
    configure_mail(cfg.mail.cooldown_sec, cfg.mail.max_consecutive_fails)
    log = Logger("main", cfg.log, cfg.base_dir)
    repo = AccountRepository(cfg.base_dir, cfg.auth_sync)

    log_fn = make_log_fn(log)
    save_fn = repo.save
    registrar = make_registrar("OPENROUTER", cfg)
    if registrar is None:
        print("ERROR: OPENROUTER registrar không tìm thấy trong registry.")
        return

    print(f"\n{_SEP}")
    print(f"  OpenRouter Account Creator  (target: {count})")
    print(_SEP)

    async def _run():
        ok = 0
        for i in range(count):
            if count > 1:
                log_fn(f"\n[{i + 1}/{count}] {'-' * 37}")
            record = await registrar(log_fn=log_fn, save_fn=save_fn)
            if record:
                ok += 1
                print(f"\n{_SEP}\nDONE [{ok}/{count}]\n{_SEP}")
                print(f"  Email:    {record.email}")
                print(f"  Password: {record.password}")
                print(_SEP)
            else:
                print(f"\nRegistration failed [{i + 1}/{count}].")
            if i < count - 1:
                log_fn(f"\nPausing {cfg.timeouts.batch_delay_sec}s...")
                await asyncio.sleep(cfg.timeouts.batch_delay_sec)
        print(f"\n{_BAR}\n  Created: {ok}/{count}\n{_BAR}")

    asyncio.run(_run())


def main_run_openrouter() -> None:
    run_openrouter(parse_count_arg(), parse_workers_arg())
